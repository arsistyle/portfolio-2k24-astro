---
import { TbLoader } from "react-icons/tb"
import { FaLinkedinIn } from "react-icons/fa"
import { getSession } from "@/utils/auth"

import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"

import { CONTACT_SUBJECTS } from "@/constants"
import Button from "@/components/core/Button/index.astro"
import Input from "@/components/form/Input.astro"
import Select from "@/components/form/Select.astro"
import Textarea from "@/components/form/Textarea.astro"
import Typography from "@/components/core/Typography/index.astro"

const { url } = Astro
const lang = getLangFromUrl(url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
const subjectOptions = [
	{ value: CONTACT_SUBJECTS.WEB_DEVELOPMENT, label: t("contact.form.subject.web") },
	{ value: CONTACT_SUBJECTS.WEB_AUDIT, label: t("contact.form.subject.audit") },
	{ value: CONTACT_SUBJECTS.OTHER, label: t("contact.form.subject.other") },
]

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "1x00000000000000000000AA"
const session = await getSession(Astro.request, import.meta.env.AUTH_SECRET)
---

<div class="mt-10 mb-16 grid grid-cols-1 items-start gap-12 md:grid-cols-[5fr_7fr] md:gap-20">
	<!-- LEFT: Info column -->
	<div class="flex flex-col gap-12">
		<Typography variant="highlight" class="text-dark max-w-sm text-pretty dark:text-white">
			{t("contact.description")}
		</Typography>

		<div class="flex flex-col gap-6">
			<Typography variant="h4" class="text-dark dark:text-white">
				{t("contact.props.heading")}
			</Typography>
			<div class="flex flex-col gap-4">
				<Typography variant="highlight" class="text-dark max-w-sm text-pretty dark:text-white">
					⚡ {t("contact.props.reply")}
				</Typography>
				<Typography variant="highlight" class="text-dark max-w-sm text-pretty dark:text-white">
					🔒 {t("contact.props.privacy")}
				</Typography>
				<Typography variant="highlight" class="text-dark max-w-sm text-pretty dark:text-white">
					🤝 {t("contact.props.transparency")}
				</Typography>
			</div>
		</div>
	</div>

	<!-- RIGHT: Form column -->
	<div class="flex flex-col gap-4">
	{session ? (
		<>
		<!-- Session Badge -->
		<div class="flex items-center justify-between gap-3 rounded-xl border border-[#0A66C2]/30 bg-[#0A66C2]/8 dark:bg-[#0A66C2]/10 px-4 py-3 mb-6">
			<div class="flex items-center gap-3">
				{
					(session as any)?.picture ? (
						<img
							src={(session as any).picture}
							alt={(session as any).name || ""}
							class="size-9 rounded-full border-2 border-[#0A66C2]/40 object-cover"
						/>
					) : (
						<div class="size-9 rounded-full bg-[#0A66C2] flex items-center justify-center text-white text-sm font-bold">
							{((session as any)?.name || "?")[0].toUpperCase()}
						</div>
					)
				}
				<div class="flex flex-col">
					<span class="text-xs text-dark/60 dark:text-gray-400">{t("contact.form.connected_as")}</span>
					<span class="text-sm font-semibold text-dark dark:text-white leading-tight">{(session as any)?.name}</span>
				</div>
			</div>
			<form method="POST" action="/api/auth/signout">
				<input type="hidden" name="callbackUrl" value={translatePath("/contact")} />
				<Button
					type="submit"
					size="sm"
					class="hover:text-red-500! dark:hover:text-red-400!"
				>
					<FaLinkedinIn slot="startIcon" />
					{t("contact.form.logout")}
				</Button>
			</form>
		</div>
		<!-- Form -->
		<form
			id="contact-form"
			class="flex flex-col gap-6"
			data-lang={lang}
			data-success={t("contact.form.success")}
			data-error={t("contact.form.error")}
			novalidate
		>
			<input type="hidden" name="lang" value={lang} />

			<div class="flex flex-col gap-5 sm:flex-row">
				<Input 
					id="name" 
					name="name" 
					label={t("contact.form.name")} 
					placeholder="John Doe" 
					value={(session as any)?.name || ""} 
					readonly 
				/>

				<Input
					type="email"
					id="email"
					name="email"
					label={t("contact.form.email")}
					placeholder="hello@example.com"
					value={(session as any)?.email || ""}
					readonly
				/>
			</div>

			<Select id="subject" name="subject" label={t("contact.form.subject")}>
				<option value="" disabled selected>{t("contact.form.subject.placeholder")}</option>
				{subjectOptions.map(({ value, label }) => <option value={value}>{label}</option>)}
			</Select>

			<Textarea id="message" name="message" label={t("contact.form.message")} placeholder="..." />

			<!-- Turnstile -->
			<div class="cf-turnstile mt-2" data-sitekey={siteKey} data-theme="auto"></div>

			<!-- Status messages -->
			<div
				id="form-status"
				class="hidden rounded-xl p-4 text-sm font-medium transition-all duration-300"
			>
			</div>

			<!-- Submit Button -->
			<Button type="submit" id="submit-btn" variant="filled" color="primary" class="w-full">
				<TbLoader className="hidden animate-spin" id="submit-spinner" slot="startIcon" />
				<span id="submit-text">{t("contact.form.submit")}</span>
			</Button>
		</form>
		</>
	) : (
		<div class="flex flex-col justify-center h-full rounded-2xl p-8 md:p-16 border border-gray-200 dark:border-white/10 bg-light dark:bg-dark-gray/50 gap-6">
			<div class="flex flex-col items-center text-center gap-3">
				<Typography variant="h4" class="text-dark dark:text-white text-pretty">
					{t("contact.form.login.title")}
				</Typography>
				<Typography variant="highlight" class="text-dark/70 dark:text-gray-300 text-pretty">
					{t("contact.form.login.description")}
				</Typography>
			</div>
			<div class="flex flex-col items-center text-center gap-6">
				<Button
					id="linkedin-popup-btn"
					type="button"
					variant="filled"
					class="bg-[#0A66C2]! hover:bg-[#004182]! border-[#0A66C2]! hover:border-[#004182]! text-white!"
				>
					<FaLinkedinIn className="size-4" slot="startIcon" />
					{t("contact.form.login.button")}
				</Button>
				<p class="text-xs text-gray-400 dark:text-gray-500">
					{t("contact.form.login.privacy")}
				</p>
			</div>
		</div>
	)}
	</div>


<script>
  const linkedinBtn = document.getElementById('linkedin-popup-btn')
  if (linkedinBtn) {
    linkedinBtn.addEventListener('click', () => {
      const popup = window.open(
        '/auth/linkedin-popup',
        'linkedin-oauth',
        'width=600,height=700,top=100,left=200,resizable=yes,scrollbars=yes'
      )

      // Listen for auth-success message from popup
      const onMessage = (e: MessageEvent) => {
        if (e.data?.type === 'auth-success') {
          window.removeEventListener('message', onMessage)
          clearInterval(checkClosed)
          window.location.reload()
        }
      }
      window.addEventListener('message', onMessage)

      // Fallback: detect popup closed manually
      const checkClosed = setInterval(() => {
        if (popup?.closed) {
          clearInterval(checkClosed)
          window.removeEventListener('message', onMessage)
          window.location.reload()
        }
      }, 800)
    })
  }
</script>

<script
	is:inline
	src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onloadTurnstileCallback"
	async
	defer></script>


<script>
	import { getContactSchema } from "@/utils/validations"

	declare global {
		interface Window {
			renderTurnstile: () => void
			onloadTurnstileCallback: () => void
			turnstile: any
		}
	}

	// 1. Safe renderer
	window.renderTurnstile = function () {
		const container = document.querySelector(".cf-turnstile") as HTMLElement | null
		if (container && window.turnstile && !container.hasChildNodes()) {
			window.turnstile.render(container, {
				sitekey: container.dataset.sitekey,
				theme: "auto",
			})
		}
	}

	// 2. Cloudflare API loaded callback (first load)
	window.onloadTurnstileCallback = function () {
		window.renderTurnstile()
	}

	// 3. Form Initialization
	function initContactForm() {
		const form = document.getElementById("contact-form") as HTMLFormElement | null
		const statusEl = document.getElementById("form-status") as HTMLDivElement | null
		const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null
		const submitText = document.getElementById("submit-text") as HTMLSpanElement | null
		const submitSpinner = document.getElementById("submit-spinner") as HTMLElement | null

		if (!form) return

		const subjectParam = new URLSearchParams(window.location.search).get("subject")
		if (subjectParam) {
			const select = document.getElementById("subject") as HTMLSelectElement | null
			if (select) {
				const normalized = subjectParam.trim().toLowerCase()
				const match = Array.from(select.options).find(
					(opt) => opt.value.toLowerCase() === normalized
				)
				if (match) select.value = match.value
			}
		}

		const lang = form.dataset.lang || "es"
		const successMsg = form.dataset.success || ""
		const errorMsg = form.dataset.error || ""

		// Force reset status when jumping between languages (SPA Morphing state leak fix)
		if (statusEl) {
			statusEl.className =
				"mt-2 hidden rounded-xl p-4 text-sm font-medium transition-all duration-300"
			statusEl.textContent = ""
		}

		// Try to render immediately if API is already loaded (View Transitions)
		if (window.turnstile) {
			window.renderTurnstile()
		}

		const schema = getContactSchema(lang)

		function clearError(id: FieldName) {
			const el = document.getElementById(id)
			const errorEl = document.getElementById("error-" + id)
			if (!el || !errorEl) return
			el.classList.remove("border-red-500", "dark:border-red-500", "ring-1", "ring-red-500")
			el.classList.add("border-gray-200", "dark:border-white/10")
			errorEl.classList.add("hidden")
		}

		function showError(id: FieldName, msg: string) {
			const el = document.getElementById(id)
			const errorEl = document.getElementById("error-" + id)
			if (!el || !errorEl) return
			el.classList.add("border-red-500", "dark:border-red-500", "ring-1", "ring-red-500")
			el.classList.remove("border-gray-200", "dark:border-white/10")
			errorEl.textContent = msg
			errorEl.classList.remove("hidden")
		}

		type FieldName = "name" | "email" | "subject" | "message"
		const fields: FieldName[] = ["name", "email", "subject", "message"]

		// Dinamically remove errors on active typing if already marked as errored
		fields.forEach((id) => {
			const el = document.getElementById(id) as
				| HTMLInputElement
				| HTMLTextAreaElement
				| HTMLSelectElement
				| null
			if (el) {
				const handler = () => {
					if (el.classList.contains("border-red-500")) {
						const parsed = schema.shape[id].safeParse(el.value)
						if (parsed.success) {
							clearError(id)
						} else {
							showError(id, parsed.error.issues[0].message)
						}
					}
				}
				// Overwrite old listeners from SPA dom-morphing
				el.oninput = handler
				el.onchange = handler
			}
		})

		function setLoading(isLoading: boolean) {
			if (!submitBtn || !submitText || !submitSpinner) return

			fields.forEach((id) => {
				const el = document.getElementById(id) as
					| HTMLInputElement
					| HTMLTextAreaElement
					| HTMLSelectElement
					| null
				if (el) {
					if (isLoading) {
						el.setAttribute("disabled", "true")
						el.classList.add("opacity-60", "cursor-not-allowed")
					} else {
						el.removeAttribute("disabled")
						el.classList.remove("opacity-60", "cursor-not-allowed")
					}
				}
			})

			if (isLoading) {
				submitBtn.setAttribute("disabled", "true")
				submitText.classList.add("hidden")
				submitSpinner.classList.remove("hidden")
			} else {
				submitBtn.removeAttribute("disabled")
				submitText.classList.remove("hidden")
				submitSpinner.classList.add("hidden")
			}
		}

		function showStatus(message: string, type: "success" | "error") {
			if (!statusEl) return
			statusEl.textContent = message
			statusEl.className =
				"rounded-xl p-4 mt-2 text-sm font-medium transition-all duration-300 block"

			if (type === "success") {
				statusEl.classList.add(
					"bg-green-50",
					"dark:bg-green-900/30",
					"text-green-800",
					"dark:text-green-300",
					"border",
					"border-green-200",
					"dark:border-green-800"
				)
				statusEl.classList.remove(
					"bg-red-50",
					"dark:bg-red-900/30",
					"text-red-800",
					"dark:text-red-300",
					"border-red-200",
					"dark:border-red-800"
				)
			} else {
				statusEl.classList.add(
					"bg-red-50",
					"dark:bg-red-900/30",
					"text-red-800",
					"dark:text-red-300",
					"border",
					"border-red-200",
					"dark:border-red-800"
				)
				statusEl.classList.remove(
					"bg-green-50",
					"dark:bg-green-900/30",
					"text-green-800",
					"dark:text-green-300",
					"border-green-200",
					"dark:border-green-800"
				)
			}
		}

		form.onsubmit = async (e: Event) => {
			e.preventDefault()

			let isValid = true
			fields.forEach((id) => {
				const el = document.getElementById(id) as
					| HTMLInputElement
					| HTMLTextAreaElement
					| HTMLSelectElement
					| null
				if (!el) return
				const parsed = schema.shape[id].safeParse(el.value)
				if (!parsed.success) {
					showError(id, parsed.error.issues[0].message)
					isValid = false
				} else {
					clearError(id)
				}
			})

			if (!isValid) return

			const formData = new FormData(form)
			const turnstileResponse = formData.get("cf-turnstile-response")

			if (!turnstileResponse) {
				showStatus(errorMsg + " (Captcha required)", "error")
				return
			}

			setLoading(true)

			try {
				const response = await fetch("/api/contact", {
					method: "POST",
					body: formData,
				})

				const result = await response.json()

				if (response.ok) {
					showStatus(successMsg, "success")
					form.reset()
					if (window.turnstile) {
						window.turnstile.reset()
					}
				} else {
					showStatus(result.error || errorMsg, "error")
				}
			} catch (error) {
				showStatus(errorMsg, "error")
			} finally {
				setLoading(false)
			}
		}
	}

	// Wait for Astro to swap pages
	document.addEventListener("astro:page-load", initContactForm)
</script>
