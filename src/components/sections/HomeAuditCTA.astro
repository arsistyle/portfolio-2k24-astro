---
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import Button from "@/components/core/Button/index.astro"
import Typography from "@/components/core/Typography/index.astro"
import { TbArrowRight, TbCheck } from "react-icons/tb"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<section class="audit-cta-section dark:bg-dark relative z-10 bg-white px-5 py-16 md:py-30">
	<div class="audit-cta-section-container container mx-auto">
		<div
			class="bg-secondary-400 dark:bg-secondary-300 relative rounded-3xl px-10 py-12 pb-24 md:px-14 md:py-16"
			transition:name="audit-card"
		>
			<Typography
				as="h6"
				class="bg-holo text-dark absolute top-[calc(100%-2rem)] right-0 left-0 mx-auto flex max-w-fit rotate-2 items-center justify-center rounded-full px-8 py-2 text-center font-black tracking-widest uppercase md:top-0 md:left-auto md:rotate-6 lg:-right-10"
				transition:name="audit-sticker"
			>
				<TbCheck className="text-dark h-10 w-10 lg:h-12 lg:w-16" />
				{t("home.audit.sticker" as any)}
			</Typography>
			<div class="relative z-10 flex flex-col gap-10 md:gap-14">
				<div class="flex flex-col items-start gap-6">
					<div class="flex flex-wrap items-center gap-3">
						<Typography
							variant="h2"
							as="h6"
							class="bg-primary-400 text-dark inline-flex rounded-none px-4 py-2"
							transition:name="audit-label"
						>
							{t("home.audit.label" as any)}
						</Typography>
					</div>
					<Typography
						variant="h3"
						as="heading2"
						class="text-dark audit-title leading-[0.9] font-black tracking-tight text-balance"
					>
						{t("home.audit.title" as any)}
					</Typography>
				</div>

				<div class="border-t-2 border-black pt-8 lg:pt-10" transition:name="audit-stats">
					<div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-0">
						<!-- Stat 1 -->
						<div class="flex flex-col gap-1 lg:border-r-2 lg:border-black lg:pr-12">
							<Typography as="heading3" class="text-dark leading-none">3</Typography>
							<Typography variant="h5" class="text-dark">
								{t("audit.hero.stats.layers" as any)}
							</Typography>
							<Typography class="text-dark">
								{t("audit.hero.stats.layers.list" as any)}
							</Typography>
						</div>

						<!-- Stat 2 -->
						<div class="flex flex-col gap-1 lg:border-r-2 lg:border-black lg:px-12">
							<Typography as="heading3" class="text-dark leading-none">1</Typography>
							<Typography variant="h5" class="text-dark">
								{t("audit.hero.stats.result" as any)}
							</Typography>
							<Typography class="text-dark">
								{t("audit.hero.stats.result.desc" as any)}
							</Typography>
						</div>

						<!-- CTA -->
						<div class="w-full lg:ml-auto lg:max-w-sm lg:pl-12">
							<Button
								tag="a"
								href={translatePath("/audit")}
								variant="filled"
								color="dark"
								size="xl"
								class="w-full"
							>
								<TbArrowRight slot="endIcon" />
								{t("home.audit.cta" as any)}
							</Button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.audit-cta-section-container {
		animation: audit-cta-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 30%;
	}

	@keyframes audit-cta-fade-up {
		from {
			opacity: 0;
			translate: 0 2rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
