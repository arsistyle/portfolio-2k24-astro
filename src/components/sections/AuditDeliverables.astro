---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import { Check } from "@/components/icons/index.astro"
import Typography from "@/components/core/Typography/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const deliverables = [
	t("audit.deliverables.1" as any),
	t("audit.deliverables.2" as any),
	t("audit.deliverables.3" as any),
	t("audit.deliverables.4" as any),
]
---

<section class="deliverables-section container mx-auto flex flex-col gap-16 px-6 pb-14 md:pb-24">
	<div class="flex flex-col gap-10">
		<Typography variant="h2" class="text-dark dark:text-white">
			{t("audit.deliverables.title" as any)}
		</Typography>
		<ul class="flex flex-col gap-6">
			{
				deliverables.map((text) => (
					<li class="grid grid-cols-[2rem_1fr] items-start gap-5 md:grid-cols-[2.5rem_1fr]">
						<div class="text-primary-500 dark:text-primary-300 mt-1 h-7 w-7 shrink-0 md:h-8 md:w-8">
							<Check />
						</div>
						<Typography variant="h5" class="text-dark leading-snug font-normal dark:text-white">
							{text}
						</Typography>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.deliverables-section {
		animation: deliverables-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 30%;
	}

	@keyframes deliverables-fade-up {
		from {
			opacity: 0;
			translate: 0 2rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
