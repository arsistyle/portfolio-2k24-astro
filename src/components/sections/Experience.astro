---
import { DATA_EXPERIENCE } from "@/content/index"
import { getLangFromUrl, useTranslations } from "@/i18n/utils"

import { Check } from "@/components/icons/index.astro"
import Typography from "@/components/core/Typography/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const { jobs }: { jobs: string[] } = DATA_EXPERIENCE[lang] || { jobs: [] }

const startDate = "2017-03-01"
const years = new Date(Date.now() - new Date(startDate).getTime()).getUTCFullYear() - 1970
const rawExperienceText = t("home.experience.title")
const experienceText = rawExperienceText.replace("{YEARS_EXPERIENCE}", String(years))
---

<section
	class="dark:bg-dark relative z-10 flex items-center justify-center bg-white px-5 pt-8 pb-14 md:pt-24 md:pb-40"
>
	<div class="container">
		<Typography
			variant="h2"
			id="experience-title"
			data-template={rawExperienceText}
			data-start={startDate}
			class="text-dark mb-12 max-w-3xl leading-tight text-balance md:mb-20 dark:text-white"
		>
			{experienceText}
		</Typography>
		<div class="grid grid-cols-2 gap-8 sm:gap-12 md:gap-20">
			{
				jobs.map((text: string) => (
					<div class="col-span-2 grid grid-cols-[2rem_1fr] gap-4 text-left md:col-span-1 md:grid-cols-[3rem_1fr]">
						<div class="text-primary-500 dark:text-primary-300 h-8 w-8 md:h-12 md:w-12">
							<Check />
						</div>
						<Typography variant="highlight" class="text-dark text-pretty dark:text-white">
							{text}
						</Typography>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	const el = document.getElementById("experience-title")
	if (el instanceof HTMLElement) {
		const years = new Date(Date.now() - new Date(el.dataset.start!).getTime()).getUTCFullYear() - 1970
		el.textContent = el.dataset.template!.replace("{YEARS_EXPERIENCE}", String(years))
	}
</script>
