---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import AuditCTA from "./AuditCTA.astro"
import AuditDeliverables from "./AuditDeliverables.astro"
import AuditLayers from "./AuditLayers.astro"
import AuditWho from "./AuditWho.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<div class="intro-section pb-14 md:pb-20">
	<p class="p highlight text-dark/60 max-w-xl text-pretty dark:text-white/60">
		{t("audit.hero.description" as any)}
	</p>
</div>

<AuditWho />
<AuditLayers />
<AuditDeliverables />
<AuditCTA />

<style>
	.intro-section {
		animation: intro-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 25%;
	}

	@keyframes intro-fade-up {
		from {
			opacity: 0;
			translate: 0 1rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
