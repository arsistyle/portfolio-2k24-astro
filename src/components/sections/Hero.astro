---
import { Image } from "astro:assets"
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import { BackgroundGrid } from "@/components/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="dark:bg-dark relative z-10 bg-white">
	<div class="flex w-full justify-center overflow-hidden px-5 py-14 md:py-40">
		<div class="container">
			<div class="grid grid-cols-2 items-center gap-8 sm:grid-cols-12">
				<div class="hero-info relative z-10 col-span-2 sm:col-span-8">
					<h1 class="mb-2">
						<div
							class="bg-secondary-400 dark:bg-secondary-300 dark:text-dark mb-2 inline-flex p-2 text-[clamp(1.6rem,5vw,3.75rem)] leading-[1em] font-bold text-white"
						>
							{t("home.hero.greeting")}
						</div>
						<div class="h1 heading text-dark font-black mix-blend-difference dark:text-white">
							<span class="whitespace-nowrap">{t("home.hero.name")}</span>
							<span class="whitespace-nowrap">{t("home.hero.lastname")}</span>
						</div>
					</h1>
					<h2
						class="text-primary-500 dark:text-primary-300 text-[clamp(1.7rem,3vw,2.875rem)] font-bold"
					>
						{t("home.hero.job")}
					</h2>
				</div>
				<div class="col-span-4 flex justify-center sm:justify-end">
					<div
						id="hero-avatar-container"
						class="avatar group relative h-80 w-80 sm:h-[450px] sm:w-[450px]"
					>
						<!-- SVG Clip Path Definition -->
						<svg class="pointer-events-none absolute h-0 w-0">
							<defs>
								<clipPath id="blob-clip" clipPathUnits="objectBoundingBox">
									<path id="blob-path" d=""></path>
								</clipPath>
							</defs>
						</svg>

						<!-- Avatar Wrapper with Dynamic Clip Path -->
						<div
							id="blob-wrapper"
							class="bg-secondary-400 dark:bg-secondary-300 relative h-full w-full overflow-hidden transition-transform duration-500 will-change-transform group-hover:scale-105"
							style="clip-path: url(#blob-clip); mask-image: linear-gradient(to bottom, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);"
						>
							<Image
								src="https://pub-e84866d2025a4715887cd3e35165cedc.r2.dev/avatar.webp"
								width={1080}
								height={1080}
								class="pointer-events-none mx-auto block h-full w-full object-cover object-bottom"
								alt="Israel Larrondo"
							/>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<BackgroundGrid class="absolute -top-96 bottom-0" />
</section>

<style>
	#hero-avatar-container {
		cursor: crosshair;
		filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.2));
	}
</style>

<script>
	// Procedural Noise for organic motion
	class Noise2D {
		p = new Uint8Array(512)
		constructor() {
			for (let i = 0; i < 256; i++) this.p[i] = this.p[i + 256] = Math.floor(Math.random() * 256)
		}
		fade(t: number) {
			return t * t * t * (t * (t * 6 - 15) + 10)
		}
		lerp(t: number, a: number, b: number) {
			return a + t * (b - a)
		}
		grad(hash: number, x: number, y: number) {
			const h = hash & 15
			const u = h < 8 ? x : y
			const v = h < 4 ? y : h === 12 || h === 14 ? x : 0
			return ((h & 1) === 0 ? u : -u) + ((h & 2) === 0 ? v : -v)
		}
		noise(x: number, y: number) {
			const X = Math.floor(x) & 255,
				Y = Math.floor(y) & 255
			x -= Math.floor(x)
			y -= Math.floor(y)
			const u = this.fade(x),
				v = this.fade(y)
			const A = this.p[X] + Y,
				AA = this.p[A],
				AB = this.p[A + 1]
			const B = this.p[X + 1] + Y,
				BA = this.p[B],
				BB = this.p[B + 1]
			return this.lerp(
				v,
				this.lerp(u, this.grad(this.p[AA], x, y), this.grad(this.p[BA], x - 1, y)),
				this.lerp(u, this.grad(this.p[AB], x, y - 1), this.grad(this.p[BB], x - 1, y - 1))
			)
		}
	}

	function initOrganicBlob() {
		const container = document.getElementById("hero-avatar-container")
		const blobPath = document.getElementById("blob-path")
		if (!container || !blobPath) return

		const noiseGen = new Noise2D()
		const numPoints = 8
		let points: { x: number; y: number; ox: number; oy: number; angle: number }[] = []
		let time = 0
		let mouse = { rawX: 0.5, rawY: 0.5, targetX: 0.5, targetY: 0.5, active: false }

		// Initialize points in a circle (0-1 range for objectBoundingBox)
		for (let i = 0; i < numPoints; i++) {
			const angle = (i / numPoints) * Math.PI * 4
			points.push({
				x: 0.5 + Math.cos(angle) * 0.5,
				y: 0.8 + Math.sin(angle) * 0.5,
				ox: Math.cos(angle) * 0.6,
				oy: Math.sin(angle) * 0.63,
				angle: angle,
			})
		}

		window.addEventListener("mousemove", (e) => {
			const rect = container.getBoundingClientRect()
			mouse.targetX = (e.clientX - rect.left) / rect.width
			mouse.targetY = (e.clientY - rect.top) / rect.height
			mouse.active = true
		})

		function animate() {
			time += 0.003

			// Smooth mouse lerp
			mouse.rawX += (mouse.targetX - mouse.rawX) * 0.1
			mouse.rawY += (mouse.targetY - mouse.rawY) * 0.1

			// Update Point Physics
			const data = points.map((p) => {
				// Organic noise wobble
				const n = noiseGen.noise(p.ox * 2 + time, p.oy * 2 + time) * 0.075
				const tx = 0.5 + p.ox + Math.cos(p.angle) * n
				const ty = 0.5 + p.oy + Math.sin(p.angle) * n

				// Magnetic pull
				if (mouse.active) {
					const dx = mouse.rawX - tx,
						dy = mouse.rawY - ty
					const dist = Math.sqrt(dx * dx + dy * dy)
					if (dist < 0.6) {
						const s = (1 - dist / 0.6) * 0.25
						p.x += (tx + dx * s - p.x) * 0.1
						p.y += (ty + dy * s - p.y) * 0.1
					} else {
						p.x += (tx - p.x) * 0.05
						p.y += (ty - p.y) * 0.05
					}
				} else {
					p.x += (tx - p.x) * 0.05
					p.y += (ty - p.y) * 0.05
				}
				return { x: p.x, y: p.y }
			})

			// Generate Smooth Path (Starting at midpoint for zero-corner wrap)
			const p0 = data[data.length - 1]
			const p1 = data[0]
			const startX = (p0.x + p1.x) / 2
			const startY = (p0.y + p1.y) / 2

			let d = `M ${startX} ${startY}`
			for (let i = 0; i < data.length; i++) {
				const curr = data[i]
				const next = data[(i + 1) % data.length]
				const midX = (curr.x + next.x) / 2
				const midY = (curr.y + next.y) / 2
				d += ` Q ${curr.x} ${curr.y}, ${midX} ${midY}`
			}
			d += " Z"

			blobPath!.setAttribute("d", d)
			requestAnimationFrame(animate)
		}

		animate()
	}

	document.addEventListener("astro:page-load", initOrganicBlob)
</script>
