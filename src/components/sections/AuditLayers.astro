---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import FlowStep from "@/components/core/FlowStep/FlowStep.astro"
import FlowSteps from "@/components/core/FlowStep/FlowSteps.astro"
import { Typography } from "@/components/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const layers = [
	{
		icon: "1",
		title: t("audit.layers.1.title" as any),
		description: t("audit.layers.1.description" as any),
	},
	{
		icon: "2",
		title: t("audit.layers.2.title" as any),
		description: t("audit.layers.2.description" as any),
	},
	{
		icon: "3",
		title: t("audit.layers.3.title" as any),
		description: t("audit.layers.3.description" as any),
	},
]
---

<section class="layers-section flex flex-col gap-8 pb-14 md:pb-20">
	<Typography type="h2" class="text-dark dark:text-white">
		{t("audit.layers.title" as any)}
	</Typography>
	<FlowSteps>
		{layers.map(({ icon, title, description }) => (
			<FlowStep {icon} {title}>
				<p>{description}</p>
			</FlowStep>
		))}
	</FlowSteps>
</section>

<style>
	.layers-section {
		animation: layers-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 30%;
	}

	@keyframes layers-fade-up {
		from {
			opacity: 0;
			translate: 0 1.5rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
