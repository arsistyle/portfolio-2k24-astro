---
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"

import { CONTACT_SUBJECTS } from "@/constants"
import Button from "@/components/core/Button/index.astro"
import Typography from "@/components/core/Typography/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<section class="cta-section container mx-auto flex flex-col gap-10 px-6 pb-14 md:pb-40">
	<div class="flex flex-col gap-10">
		<div class="flex items-center gap-4">
			<span
				class="font-syne text-primary-500 dark:text-primary-300 text-4xl leading-none font-black"
				>→</span
			>
			<div class="bg-dark/10 h-px flex-1 dark:bg-white/10"></div>
		</div>

		<div class="flex flex-col items-start gap-8 md:flex-row md:items-end md:justify-between">
			<Typography variant="h2" class="text-dark max-w-xl text-pretty dark:text-white">
				{t("audit.cta.title" as any)}
			</Typography>
			<div class="shrink-0">
				<Button
					tag="a"
					href={`${translatePath("/contact")}?subject=${encodeURIComponent(CONTACT_SUBJECTS.WEB_AUDIT)}`}
					variant="filled"
					color="primary"
					size="xl"
				>
					{t("audit.cta.button" as any)}
				</Button>
			</div>
		</div>
	</div>
</section>

<style>
	.cta-section {
		animation: cta-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 30%;
	}

	@keyframes cta-fade-up {
		from {
			opacity: 0;
			translate: 0 2rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
