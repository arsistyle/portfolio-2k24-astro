---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import { Button, Typography } from "@/components/index.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="cta-section pb-14 md:pb-40">
	<div
		class="bg-primary-400 dark:bg-primary-400 flex flex-col items-center gap-8 rounded-3xl px-8 py-14 text-center md:px-20 md:py-20"
	>
		<Typography type="h2" class="max-w2xl text-dark text-pretty">
			{t("audit.cta.title" as any)}
		</Typography>
		<Button tag="a" href="/contact" variant="filled" color="dark" size="xl">
			{t("audit.cta.button" as any)}
		</Button>
	</div>
</section>

<style>
	.cta-section {
		animation: cta-fade-up linear both;
		animation-timeline: view();
		animation-range: entry 0% cover 30%;
	}

	@keyframes cta-fade-up {
		from {
			opacity: 0;
			translate: 0 2rem;
		}
		to {
			opacity: 1;
			translate: 0 0;
		}
	}
</style>
