---
import { GoArrowRight } from "react-icons/go"
import { Typography } from "@/components/index.astro"
import { getCategoryConfig } from "@/config/categories"
import { twMerge } from "tailwind-merge"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import { FiClock } from "react-icons/fi"

interface Props {
	title: string
	description: string
	search_context: string
	date: string
	categories: string[]
	href: string
	slug: string
	image: string
	readingTime?: number
}

const { title, description, search_context, categories, href, slug, image, readingTime } =
	Astro.props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const enrichedCategories = categories.map((slug) => {
	const config = getCategoryConfig(slug)
	return {
		slug,
		...config,
	}
})
---

<article
	class="blog-card group data-animating:animate-blog-card-in relative col-span-1 md:col-span-2 xl:col-span-3"
	data-categories={categories.join(",")}
	data-search={`${title} ${search_context} ${description}`}
>
	<div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
		<a href={href} class="group relative col-span-1 aspect-video w-full overflow-hidden rounded-3xl md:col-span-1">
			<div
				class="text-dark group-hover:bg-primary-500 dark:group-hover:bg-primary-300 absolute top-5 right-5 z-10 flex h-12 w-12 -rotate-45 items-center justify-center rounded-full bg-white p-2 transition group-hover:translate-x-2 group-hover:-translate-y-2 group-hover:scale-125 group-hover:rotate-0"
			>
				<GoArrowRight className="h-full w-full" />
			</div>
			<img
				src={image}
				class="absolute inset-0 h-full w-full rounded-3xl object-cover transition-transform group-hover:scale-105"
				alt={title}
				loading="lazy"
				decoding="async"
				transition:name={`blog-image-${slug}`}
				width={1280}
				height={720}
			/>
			{
				readingTime && (
					<div
						transition:name={`blog-reading-time-${slug}`}
						class="text-dark dark:bg-dark/80 absolute top-5 left-5 z-20 flex items-center gap-1.5 rounded-2xl bg-white/90 px-3 py-1.5 text-xs font-semibold dark:text-white"
					>
						<FiClock className="text-sm" />
						<span>
							{readingTime} {t("blog.readingTime")}
						</span>
					</div>
				)
			}
		</a>
		<div class="relative inset-0 z-20 col-span-1 flex w-full flex-col gap-4 xl:col-span-1">
			<a href={href} class="group flex flex-col gap-4">
				<Typography
					variant="h3"
					as="h1"
					class="text-dark group-hover:text-primary-500 dark:group-hover:text-primary-300 leading-[1.2em] transition-colors dark:text-white"
					transition:name={`blog-title-${slug}`}
				>
					{title}
				</Typography>
				<Typography variant="highlight" class="text-dark/70 leading-[170%]! dark:text-white/75">
					{description}
				</Typography>
			</a>
			{
				enrichedCategories.length > 0 && (
					<div class="flex flex-wrap gap-2">
						{enrichedCategories.map((cat) => {
							const Icon = cat.icon

							return (
								cat.label && (
									<a
										href={translatePath(`/blog?categories=${cat.slug}`)}
										class={twMerge(
											"border-dark/60 text-dark flex cursor-pointer items-center gap-1.5 rounded-full border px-2 py-1 text-xs font-semibold transition-all duration-200 select-none dark:border-white/70 dark:text-white/70 dark:hover:border-white dark:hover:text-white",
											cat.className
										)}
									>
										{Icon && (
											<span class="icon text-lg leading-1">
												<Icon />
											</span>
										)}
										{cat.label}
									</a>
								)
							)
						})}
					</div>
				)
			}
		</div>
	</div>
</article>
