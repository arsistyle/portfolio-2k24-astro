---
import { Typography } from "@/components/index.astro"
import { getLangFromUrl, useTranslations } from "@/i18n/utils"

interface Source {
	url: string
	title?: string
}

interface Props {
	sources: Source[]
	title?: string
}

const { sources, title } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const displayTitle = title || t("blog.sources")

const getDomain = (url: string) => {
	try {
		return new URL(url).hostname.replace("www.", "")
	} catch {
		return url
	}
}

const getFavicon = (url: string): string | null => {
	try {
		const domain = new URL(url).hostname
		return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`
	} catch {
		return null
	}
}
---

<section class="sources-container rounded-2xl">
	<div class="mb-4 flex items-center gap-2">
		<Typography type="h5" class="text-dark/90 text-sm font-medium dark:text-white/90">
			{displayTitle}
		</Typography>
	</div>

	<div class="grid grid-cols-1 gap-2">
		{
			sources.map((source) => {
				const favicon = getFavicon(source.url)
				const domain = getDomain(source.url)
				const label = source.title || domain

				return (
					<a
						href={source.url}
						target="_blank"
						rel="noopener noreferrer"
						class="group flex items-center gap-3 rounded-xl bg-black/5 p-3 transition-all hover:bg-black/10 dark:bg-white/5 dark:hover:bg-white/10"
					>
						<div class="flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-full bg-black/10 dark:bg-white/10">
							{favicon && (
								<img src={favicon} alt="" class="h-5 w-5" onerror="this.style.display='none'" />
							)}
						</div>
						<div class="flex min-w-0 flex-col">
							<span class="text-dark/40 group-hover:text-dark/60 text-[10px] font-semibold tracking-wider uppercase transition-colors dark:text-white/40 dark:group-hover:text-white/60">
								{domain}
							</span>
							<Typography
								type="span"
								class="text-dark/80 group-hover:text-dark line-clamp-1 text-sm dark:text-white/80 dark:group-hover:text-white"
							>
								{label}
							</Typography>
						</div>
					</a>
				)
			})
		}
	</div>
</section>
