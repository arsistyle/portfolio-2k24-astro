---
import { TbChevronLeft, TbChevronRight } from "react-icons/tb"
import { getBlogPosts } from "@/utils/getBlogPosts"
import { useTranslatedPath } from "@/i18n/utils"
import type { Langs } from "@/types"

interface Props {
	slug: string
	lang: Langs
	basePath: string
	prevLabel?: string
	nextLabel?: string
}

const { slug, lang, basePath, prevLabel = "Previous", nextLabel = "Next" } = Astro.props

const allPosts = getBlogPosts({ lang })
const now = new Date()
const isDev = import.meta.env.DEV

// Filter valid posts similar to the original logic
const posts = allPosts
	.filter((p) => p.status === "active" && (isDev || new Date(p.date) <= now))
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())

const idx = posts.findIndex((p) => p.slug === slug)
const prev = idx > 0 ? posts[idx - 1] : null
const next = idx >= 0 && idx < posts.length - 1 ? posts[idx + 1] : null

if (!prev && !next) return null
---

<nav
	class="mt-12 grid grid-cols-1 gap-4 border-t border-gray-200 py-8 sm:grid-cols-2 dark:border-gray-800"
>
	{
		prev ? (
			<a
				href={useTranslatedPath(lang)(`${basePath}/${prev.slug}`)}
				class="group flex items-center gap-3 rounded-2xl border border-gray-200 p-4 transition-all duration-200 hover:border-gray-400 hover:bg-gray-50 dark:border-gray-800 dark:hover:border-gray-600 dark:hover:bg-white/[0.03]"
			>
				<span class="text-gray-400 transition-transform duration-200 group-hover:-translate-x-1 dark:text-gray-500">
					<TbChevronLeft size={20} />
				</span>
				<div class="flex min-w-0 flex-col">
					<span class="text-xs font-medium text-gray-400 dark:text-gray-500">{prevLabel}</span>
					<span class="max-w-full truncate text-sm font-semibold text-gray-700 dark:text-gray-200">
						{prev.title}
					</span>
				</div>
			</a>
		) : (
			<div />
		)
	}

	{
		next ? (
			<a
				href={useTranslatedPath(lang)(`${basePath}/${next.slug}`)}
				class="group flex items-center justify-end gap-3 rounded-2xl border border-gray-200 p-4 text-right transition-all duration-200 hover:border-gray-400 hover:bg-gray-50 dark:border-gray-800 dark:hover:border-gray-600 dark:hover:bg-white/[0.03]"
			>
				<div class="flex min-w-0 flex-col items-end">
					<span class="text-xs font-medium text-gray-400 dark:text-gray-500">{nextLabel}</span>
					<span class="max-w-full truncate text-sm font-semibold text-gray-700 dark:text-gray-200">
						{next.title}
					</span>
				</div>
				<span class="text-gray-400 transition-transform duration-200 group-hover:translate-x-1 dark:text-gray-500">
					<TbChevronRight size={20} />
				</span>
			</a>
		) : (
			<div />
		)
	}
</nav>
