---
import { useTranslatedPath, useTranslations } from "@/i18n/utils"
import PageLayout from "@/layouts/PageLayout.astro"
import { getBlogPosts, getCategoriesWithCount } from "@/utils/getBlogPosts"
import BlogCard from "@/components/core/BlogCard/BlogCard.astro"
import CategoryFilter from "@/components/core/CategoryFilter/CategoryFilter"
import { Typography } from "@/components/index.astro"
import { CATEGORIES } from "@/config/categories"
import type { Langs, BreadcrumbsItem } from "@/types"
import type { Page } from "astro"
import Pagination from "@/components/core/Pagination/Pagination.astro"
import BlogCardFirst from "@/components/core/BlogCard/BlogCardFirst.astro"

interface Props {
	lang: Langs
	title: string
	pageTitle: string
	breadcrumbs: BreadcrumbsItem[]
	page: Page<any>
	description?: string
	og_title?: string
	og_image?: string
	isFirstPage?: boolean
}

const { lang, title, pageTitle, breadcrumbs, page, description, og_title, og_image, isFirstPage } =
	Astro.props

const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const allPosts = getBlogPosts({ lang })
const posts = page.data
const categoriesWithCount = getCategoriesWithCount(allPosts, CATEGORIES)
const hasPosts = posts.length > 0
const hasCategories = categoriesWithCount.length > 0
---

<PageLayout
	{title}
	{description}
	og_title={og_title || pageTitle}
	{og_image}
	{pageTitle}
	{breadcrumbs}
>
	<div class="flex min-h-[70vh] flex-col gap-8 pb-12 md:gap-12">
		{
			hasCategories && (
				<CategoryFilter
					categories={categoriesWithCount}
					allLabel={t("blog.all")}
					noResultsLabel={t("blog.noResults")}
					searchPlaceholder={t("blog.search")}
					resultsLabel={t("blog.results")}
					filterLabel={t("blog.filter")}
					clearAllLabel={t("blog.clearAll")}
					confirmLabel={t("blog.confirm")}
					resultCount={page.total}
					client:load
				/>
			)
		}

		{
			hasPosts ? (
				<>
					<div class="grid grid-cols-1 gap-12 md:grid-cols-2 xl:grid-cols-3">
						{posts.map((post: any, key: number) => {
							const hasFilters = Astro.url.searchParams.has("q") || Astro.url.searchParams.has("categories")
							const fullCard = isFirstPage && key === 0 && !hasFilters
							return fullCard ? (
								<BlogCardFirst
									title={post.title}
									description={post.description}
									search_context={post.search_context}
									date={post.date}
									categories={post.categories}
									href={translatePath(`/blog/${post.slug}`)}
									slug={post.slug}
									image={post.image}
									readingTime={post.readingTime}
								/>
							) : (
								<BlogCard
									title={post.title}
									description={post.description}
									search_context={post.search_context}
									date={post.date}
									categories={post.categories}
									href={translatePath(`/blog/${post.slug}`)}
									slug={post.slug}
									image={post.image}
									readingTime={post.readingTime}
								/>
							)
						})}
					</div>

					<Pagination {page} {lang} class="mt-12" />
				</>
			) : (
				<div class="flex min-h-[50vh] flex-col items-center justify-center rounded-4xl border border-dashed border-gray-300 px-8 py-20 text-center dark:border-gray-700">
					<Typography type="h5" class="text-gray-500 dark:text-gray-400">
						{page.total === 0 &&
						(Astro.url.searchParams.get("q") || Astro.url.searchParams.get("categories"))
							? t("blog.noResults")
							: t("blog.empty")}
					</Typography>
				</div>
			)
		}
	</div>
</PageLayout>
