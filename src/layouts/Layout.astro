---
import { ClientRouter } from "astro:transitions"
import { SEO } from "astro-seo"
import "@fontsource-variable/syne"

import { getLangFromUrl } from "@/i18n/utils"

import Header from "@/components/shared/Header.astro"
import Footer from "@/components/shared/Footer.astro"

import "@/css/global.css"
import { SEO_DATA, TWITTER_HANDLE } from "@/constants"

interface Props {
	title: string
	showHeader?: boolean
	showFooter?: boolean
	description?: string
	og_image?: string
	og_title?: string
	og_type?: string
	canonical?: string
}

const { props } = Astro
const lang = getLangFromUrl(Astro.url)

const {
	title = SEO_DATA[lang].title,
	description,
	og_image = SEO_DATA[lang].image,
	og_title,
	og_type = "website",
	canonical,
	showHeader = true,
	showFooter = true,
} = props
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<SEO
			title={title}
			description={description || SEO_DATA[lang].description}
			canonical={canonical || Astro.url.href}
			openGraph={{
				basic: {
					title: og_title || title,
					image: og_image,
					type: og_type,
					url: Astro.url.href,
				},
				optional: {
					description,
				},
			}}
			twitter={{
				card: "summary_large_image",
				site: TWITTER_HANDLE,
				creator: TWITTER_HANDLE,
				title: og_title || title,
				description,
				image: og_image,
			}}
		/>
		<script
			async
			src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5806103815269616"
			crossorigin="anonymous"
			is:inline></script>
		<ClientRouter />
	</head>

	<body class="dark:bg-dark flex min-h-screen flex-col bg-white">
		{showHeader && <Header />}
		<slot />
		{showFooter && <Footer />}
	</body>
</html>
