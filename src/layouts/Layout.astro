---
import { ClientRouter } from "astro:transitions"
import { SEO } from "astro-seo"
import "@fontsource-variable/syne"
import "@fontsource-variable/google-sans-flex"

import { getLangFromUrl } from "@/i18n/utils"

import Header from "@/components/shared/Header.astro"
import Footer from "@/components/shared/Footer.astro"
import AdSenseInit from "@/components/core/AdSlot/AdSenseInit.astro"

import "@/css/global.css"
import { TWITTER_HANDLE, MAIN_URL, FB_APP_ID } from "@/constants"

interface Props {
	title?: string
	showHeader?: boolean
	showFooter?: boolean
	description?: string
	og_image?: string
	og_title?: string
	og_type?: string
	canonical?: string
}

import { getEntry } from "astro:content"

const { props } = Astro
const lang = getLangFromUrl(Astro.url)

const homeSeoEntry = await getEntry("seo", lang as any)
const defaultSeo = (homeSeoEntry as any)?.data?.pages?.home

const {
	title: raw_title,
	description: raw_description,
	og_image: raw_og_image,
	og_title: raw_og_title,
	og_type = "website",
	canonical: raw_canonical,
	showHeader = true,
	showFooter = true,
} = props

// Robust defaults from Home SEO
const title = raw_title || defaultSeo?.title || ""
const description = raw_description || defaultSeo?.description || ""
const og_title = raw_og_title || defaultSeo?.og_title || title
const final_raw_og_image = raw_og_image || defaultSeo?.og_image

// Ensure absolute URLs for social images and canonical
const normalizeUrl = (base: string, path?: string) => {
	if (!path) return undefined
	if (path.startsWith("http")) return path
	const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base
	const cleanPath = path.startsWith("/") ? path : `/${path}`
	return `${cleanBase}${cleanPath}`
}

const og_image = normalizeUrl(MAIN_URL, final_raw_og_image)
const canonical = raw_canonical
	? raw_canonical.startsWith("http")
		? raw_canonical
		: normalizeUrl(MAIN_URL, raw_canonical)
	: Astro.url.href
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta property="fb:app_id" content={FB_APP_ID} />
		<SEO
			title={title || ""}
			description={description || ""}
			canonical={canonical || ""}
			openGraph={{
				basic: {
					title: og_title || title || "",
					image: og_image || "",
					type: og_type,
					url: Astro.url.href,
				},
				optional: {
					description: description || "",
				},
			}}
			twitter={{
				card: "summary_large_image",
				site: TWITTER_HANDLE,
				creator: TWITTER_HANDLE,
				title: og_title || title || "",
				description: description || "",
				image: og_image || "",
			}}
		/>
		<script
			async
			src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5806103815269616"
			crossorigin="anonymous"
			is:inline></script>
		<ClientRouter />
	</head>

	<body class="dark:bg-dark flex min-h-screen flex-col bg-white">
		{showHeader && <Header />}
		<slot />
		{showFooter && <Footer />}
		<div id="modal-root"></div>
		<AdSenseInit />
	</body>
</html>
