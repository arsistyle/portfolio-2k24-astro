---
export const prerender = false;
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import PageLayout from "@/layouts/PageLayout.astro"
import ContactForm from "@/components/sections/ContactForm.astro"
import { getEntry } from "astro:content"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const seoEntry = await getEntry("seo", "en" as any)
const seo = (seoEntry as any)?.data?.pages?.contact

const breadcrumbs = [
	{
		name: t("nav.home"),
		type: "link",
		url: translatePath("/"),
	},
	{
		type: "separator",
	},
	{
		name: t("nav.contact"),
		type: "current",
	},
]
---

<PageLayout
  title={seo?.title}
  description={seo?.description}
  og_title={seo?.og_title}
  og_image={seo?.og_image}
  pageTitle={t("contact.title")}
  {breadcrumbs}
>
  <section class="min-h-[70vh] flex flex-col justify-center relative">
    <ContactForm />
  </section>
</PageLayout>
