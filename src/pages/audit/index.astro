---
import AuditService from "@/components/sections/AuditService.astro"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import Layout from "@/layouts/Layout.astro"
import { getEntry } from "astro:content"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const seoEntry = await getEntry("seo", lang as any)
const seo = (seoEntry as any)?.data?.pages?.audit
---

<Layout
	title={seo?.title}
	description={seo?.description}
	og_title={seo?.og_title}
	og_image={seo?.og_image}
>
	<div class="dark:bg-dark relative z-10 overflow-x-clip bg-white">
		<AuditService />
	</div>
</Layout>
