---
import AuditService from "@/components/sections/AuditService.astro"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import PageLayout from "@/layouts/PageLayout.astro"
import { getEntry } from "astro:content"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const seoEntry = await getEntry("seo", lang as any)
const seo = (seoEntry as any)?.data?.pages?.audit

const breadcrumbs = [
	{
		name: t("nav.home"),
		type: "link",
		url: translatePath("/"),
	},
	{
		type: "separator",
	},
	{
		name: t("nav.audit" as any),
		type: "current",
	},
]
---

<PageLayout
	title={seo?.title}
	description={seo?.description}
	og_title={seo?.og_title}
	og_image={seo?.og_image}
	pageTitle={t("audit.title" as any)}
	{breadcrumbs}
>
	<AuditService />
</PageLayout>
