---
import type { Langs } from "@/types"

import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"

import PageLayout from "@/layouts/PageLayout.astro"
import { getBlogPosts } from "@/utils/getBlogPosts"

export async function getStaticPaths() {
	const lang: Langs = "es"
	const postList = getBlogPosts({ lang })

	return postList.map((post) => {
		return {
			params: { slug: post.slug },
			props: { post },
		}
	})
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
const { post } = Astro.props
const { title, Content, slug, image } = post

const breadcrumbs = [
	{
		name: t("nav.home"),
		type: "link",
		url: translatePath("/"),
	},
	{
		type: "separator",
	},
	{
		name: t("nav.blog"),
		type: "link",
		url: translatePath("/blog"),
	},
	{
		type: "separator",
	},
	{
		name: title,
		type: "current",
	},
]
---

<PageLayout title={`Israel Larrondo | Blog - ${title}`} pageTitle={title} {breadcrumbs}>
	<article class="blog-article">
		<div class="blog-hero-image">
			<img src={image} alt={title} transition:name={`blog-image-${slug}`} />
		</div>
		<Content />
	</article>
</PageLayout>
