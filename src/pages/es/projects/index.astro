---
import ProjectsAll from "@/components/sections/ProjectsAll.astro"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils"
import PageLayout from "@/layouts/PageLayout.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

import { getEntry } from "astro:content"
const seoEntry = await getEntry("seo", lang as any)
const seo = (seoEntry as any)?.data?.pages?.projects

const breadcrumbs = [
	{
		name: t("nav.home"),
		type: "link",
		url: translatePath("/"),
	},
	{
		type: "separator",
	},
	{
		name: t("nav.projects"),
		type: "current",
	},
]
---

<PageLayout
	title={seo?.title || "Israel Larrondo | Proyectos"}
	description={seo?.description}
	og_title={seo?.og_title}
	og_image={seo?.og_image}
	pageTitle={t("projects.title")}
	{breadcrumbs}
>
	<ProjectsAll />
</PageLayout>
