---
export const prerender = false
---

<!doctype html>
<html>
	<head>
		<meta charset="UTF-8" />
		<title>Authenticated</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
				margin: 0;
				background: #0f0f0f;
				color: #fff;
			}
			p {
				opacity: 0.6;
			}
		</style>
	</head>
	<body>
		<p>✓ Autenticado. Cerrando...</p>
		<script>
			if (window.opener) {
				window.opener.postMessage({ type: "auth-success" }, window.location.origin)
				window.close()
			} else {
				window.location.href = "/contact"
			}
		</script>
	</body>
</html>
